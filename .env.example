# GIFTED Environment Variables
# Copy this file to .env.local and fill in your values

# ==============================================
# APP CONFIGURATION
# ==============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GIFTED

# ==============================================
# RELOADLY INTEGRATION (Gift Card Catalog)
# ==============================================
# Sign up at: https://www.reloadly.com/
# Documentation: https://developers.reloadly.com/

# OAuth credentials from Reloadly dashboard
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=

# API endpoint (use sandbox for testing)
RELOADLY_API_URL=https://giftcards.reloadly.com
# RELOADLY_API_URL=https://giftcards-sandbox.reloadly.com

# Toggle sandbox mode (true for testing, false for production)
RELOADLY_SANDBOX=true

# ==============================================
# LEMON SQUEEZY INTEGRATION (Payment Processing)
# ==============================================
# Sign up at: https://lemonsqueezy.com
# Documentation: https://docs.lemonsqueezy.com/api

# API key from Settings > API
LEMON_SQUEEZY_API_KEY=

# Store ID from dashboard
LEMON_SQUEEZY_STORE_ID=

# Product variant ID (create a "Gift Card" product in dashboard)
LEMON_SQUEEZY_VARIANT_ID=

# Webhook secret from Settings > Webhooks
# Used to verify webhook signatures
LEMON_SQUEEZY_WEBHOOK_SECRET=

# ==============================================
# DATABASE (Order Persistence)
# ==============================================
# PostgreSQL, Supabase, PlanetScale, etc.
# Example: postgresql://user:password@localhost:5432/gifted
DATABASE_URL=

# ==============================================
# EMAIL DELIVERY (Gift Card Codes)
# ==============================================
# Resend, SendGrid, Postmark, etc.
# Example: https://resend.com

# Resend API key
RESEND_API_KEY=

# From email address (must be verified domain)
EMAIL_FROM=noreply@yourdomain.com

# ==============================================
# ANALYTICS (Optional)
# ==============================================
# PostHog, Plausible, Google Analytics, etc.

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ==============================================
# SECURITY & MONITORING
# ==============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Sentry Error Tracking
# Sign up at: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=

# Upstash Redis (Rate Limiting)
# Sign up at: https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ==============================================
# NOTES
# ==============================================
# 1. Never commit .env.local to version control
# 2. Use different credentials for dev/staging/production
# 3. Rotate secrets regularly
# 4. Store production secrets in your hosting platform's dashboard
#    (Vercel, Netlify, etc.)
