# Reloadly Gift Card API
RELOADLY_CLIENT_ID=your_client_id_here
RELOADLY_CLIENT_SECRET=your_client_secret_here
RELOADLY_SANDBOX=true  # Set to false for production

# Lemon Squeezy Payments
LEMON_SQUEEZY_API_KEY=your_api_key_here
LEMON_SQUEEZY_STORE_ID=your_store_id_here
LEMON_SQUEEZY_VARIANT_ID=your_variant_id_here
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/gifted

# Email (Resend)
RESEND_API_KEY=your_resend_api_key_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
